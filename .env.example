# =============================================================================
# Credenciais do Mercado Livre — usadas SÓ pelo backend (/api/ml-produto)
# para a busca automática de produtos. Os segredos ficam no servidor e
# NUNCA são enviados ao navegador.
#
# Como obter:
#   1. Acesse https://developers.mercadolivre.com.br/ e faça login.
#   2. Em "Suas aplicações", crie uma aplicação.
#   3. Copie o "App ID" (Client ID) e a "Secret Key" (Client Secret).
#
# Como usar:
#   - LOCAL: copie este arquivo para ".env" e preencha os valores.
#   - VERCEL: cole os valores em Settings > Environment Variables (recomendado).
#
# O arquivo ".env" está no .gitignore e não deve ser comitado.
# =============================================================================

# Recomendado: o backend gera e renova o token automaticamente.
ML_CLIENT_ID=
ML_CLIENT_SECRET=

# Alternativa rápida para teste (token expira em ~6h; tem prioridade se preenchido).
# ML_ACCESS_TOKEN=


# =============================================================================
# Login (acesso restrito)
# =============================================================================
# Defina APP_PASSWORD para EXIGIR senha no app. Sem ela, o app fica em
# "modo aberto" (qualquer um com o link acessa). A senha fica só no servidor.
APP_PASSWORD=

# Opcional: segredo para assinar o cookie de sessão. Se vazio, é derivado da
# APP_PASSWORD. Defina um valor próprio (string aleatória longa) se preferir.
# SESSION_SECRET=
